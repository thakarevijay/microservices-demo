<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet config.
    <clear /> drops machine/user-level sources (e.g. private feeds like 'Goyard package')
    so this project only restores from nuget.org. Keeps CI builds reproducible across
    machines and satisfies CPM's NU1507 (which forbids ambiguous sources).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
